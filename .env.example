# ============================================================
# Environment Variables - Dinas Perindag Kabupaten Ngada E-Catalog
# ============================================================
# Copy this file to `.env` and fill in real values.
# NEVER commit the real `.env` file.

# ---- Database (Supabase PostgreSQL) ----
# Transaction pooler (port 6543) - for serverless runtime (app)
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct connection (port 5432) - for Prisma migrations
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# ---- Admin Authentication ----
# Generate with: openssl rand -hex 32
ADMIN_JWT_SECRET=your-generated-64-char-hex-secret

# ---- Public (exposed to browser) ----
# WhatsApp number for product order/inquiry links
NEXT_PUBLIC_ADMIN_WA=6281313620658

# ---- Image Upload Storage (Supabase Storage) ----
# REQUIRED on Vercel/serverless for admin image uploads to persist.
# On local dev, uploads fall back to public/uploads/ (filesystem).
#
# 1. Create a PUBLIC bucket named "product-images" in your Supabase project
#    (Dashboard → Storage → New bucket → Public = ON).
# 2. Copy the project URL and service_role key from
#    Dashboard → Project Settings → API.
SUPABASE_URL=https://jscdahwphgfmfgwavhxn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Optional: override bucket name (defaults to "product-images")
# SUPABASE_PRODUCT_BUCKET=product-images
