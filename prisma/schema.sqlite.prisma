// Local development schema (SQLite)
// Used by: bun run dev, bun run db:push, bun run seed
// Production (Vercel) uses prisma/schema.prisma (PostgreSQL) instead.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  category    String        // 'tenun', 'songket', 'kopi', or 'bambu'
  price       Int           // Price in IDR
  description String
  artisanInfo String?       // Deskripsi lengkap IKM / pengrajin (multi-baris)
  ikmId       String?       // FK ke Ikm (1 IKM bisa banyak produk)
  ikm         Ikm?          @relation(fields: [ikmId], references: [id], onDelete: SetNull)
  whatsappNumber String?    // Nomor WA khusus produk ini (fallback ke admin global)
  marketplaceUrl String?    // Link marketplace (FB Marketplace, Tokopedia, Shopee, dll)
  specifications String?   // Spesifikasi barang (ukuran, berat, bahan, dll) - multi-baris
  imageUrl    String
  isFeatured  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  views       ProductView[]

  @@index([ikmId])
}

model Ikm {
  id              String    @id @default(cuid())
  name            String    @unique
  slug            String    @unique
  description     String?   // Deskripsi / sejarah IKM (multi-baris)
  category        String    // Kategori utama untuk badge/icon: 'tenun', 'songket', 'kopi', 'bambu'
  address         String?   // Alamat lengkap
  phone           String?   // Nomor telepon
  whatsappNumber  String?   // Nomor WhatsApp untuk pemesanan
  marketplaceUrl  String?   // Link marketplace utama
  establishedYear Int?      // Tahun berdiri
  leaderName      String?   // Nama ketua/pimpinan IKM
  memberCount     Int?      // Jumlah anggota pengrajin
  isFeatured      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]

  @@index([category])
}

model SiteProfile {
  id          String        @id @default("singleton")
  officeName      String    // Nama kantor resmi
  address         String    // Alamat lengkap kantor
  history         String    // Sejarah singkat (multi-paragraf)
  leaderName      String?   // Nama pimpinan/kadis
  leaderPosition  String?   // Jabatan pimpinan
  leaderPhoto     String?   // URL foto pimpinan
  vision          String    // Visi
  mission         String    // Misi (multi-baris, tiap baris satu misi)
  duties          String?   // Tugas pokok (multi-baris)
  functions       String?   // Fungsi (multi-baris)
  email           String?   // Email resmi
  phone           String?   // Telepon resmi
  workingHours    String?   // Jam kerja
  mapEmbed        String?   // URL embed google maps
  updatedAt   DateTime      @updatedAt
}

model ProductView {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@index([productId])
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed password
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
